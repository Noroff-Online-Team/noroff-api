{
  "name": "@noroff/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for Noroff API v2",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/demo.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "test": "vitest"
  },
  "dependencies": {
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.11",
    "tsup": "^7.2.0",
    "tsx": "^4.1.4",
    "typescript": "^5.2.2",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "author": "Noroff School of Technology and Digital Media",
  "license": "UNLICENSED"
}
